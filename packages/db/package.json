{
  "name": "@Manujujaya-Manajemen-stock/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:local": "bun -e \"import { Database } from 'bun:sqlite'; const db = new Database('local.db', { create: true }); db.close(); console.log('SQLite ready at packages/db/local.db');\"",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@Manujujaya-Manajemen-stock/env": "workspace:*",
    "@libsql/client": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "libsql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@Manujujaya-Manajemen-stock/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5"
  }
}
